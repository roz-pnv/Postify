# Environment
APP_ENV=test
APP_DEBUG=true
APP_URL=http://localhost

# PHP
PHP_VERSION=8.2-fpm
PHP_INI_PATH=./etc/php/php.ini

# MySQL
MYSQL_VERSION=8.0.34
MYSQL_HOST=mysql
MYSQL_PORT=3307
MYSQL_PORT_INTERNAL=3306
MYSQL_DATABASE=your_db_name_test
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# Session
SESSION_DRIVER=files
SESSION_LIFETIME=120

# JWT
JWT_SECRET=your_super_secret_key
JWT_EXPIRY=3600

# Logging
LOG_PATH=data/logs/test.log
